// ── test3.slvt — Compute Kernel 예제 ─────────────────────────
// GPU에서 병렬로 배열 원소를 2배로 만드는 단순 컴퓨트 셰이더.
// @kernel 어트리뷰트로 compute 파이프라인을 사용한다.
//
// 실제 Metal에서 커널 버퍼 파라미터는:
//   device float* data  [[buffer(0)]]
//   constant uint& count [[buffer(1)]]
// 형태지만, Salvation에서는 타입만 선언하면 codegen이 어노테이션을 붙인다.

@backend(metal)
fn main() {
    // salvation이 Metal compute 보일러플레이트를 자동 생성한다.
}

// ── kernel ────────────────────────────────────────────────────
// 각 스레드가 자신의 인덱스에 해당하는 원소를 2배로 만든다.
// idx:   스레드 인덱스 (threadgroup에서 자동 주입)
// count: 배열 원소 개수 (CPU에서 전달하는 상수)
// data:  입출력 버퍼 (float 원소, CPU에서 전달)
@backend(metal) @kernel
fn double_array(idx: uint, count: uint, data: float) {
    // 인덱스가 범위를 벗어나면 즉시 반환 (가드 클로즈)
    if (idx >= count) {
        return;
    }
    let mut val: float = data[idx];
    val *= 2.0f;
    data[idx] = val;
}

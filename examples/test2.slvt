// ── test2.slvt — 텍스처 샘플링 예제 ──────────────────────────
// UV 좌표를 받아서 텍스처에서 색상을 샘플링하는 기본 셰이더.
// texture2d / sampler 타입을 사용한다.

@backend(metal)
fn main() {
    // salvation이 Metal 보일러플레이트를 자동 생성한다.
}

// ── vertex shader ─────────────────────────────────────────────
// position: 클립 공간 좌표 (float4)
// uv:       텍스처 좌표 0~1 (float2 — fragment로 전달)
@backend(metal) @vertex
fn vert(position: float4, uv: float2) -> float4 {
    return position;
}

// ── fragment shader ───────────────────────────────────────────
// uv를 받아서 texture로부터 색상을 샘플링한다.
@backend(metal) @fragment
fn frag(uv: float2) -> float4 {
    // 실제 텍스처 샘플링은 Metal 내장 함수 sample()을 사용한다.
    // 현재 salvation codegen은 Call expr로 처리함.
    return sample(albedo, smp, uv);
}

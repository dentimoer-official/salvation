// ── test2.slvt — 텍스처 샘플링 예제 ──────────────────────────
// UV 좌표를 받아서 텍스처에서 색상을 샘플링하는 기본 셰이더.
// texture2d / sampler 타입 파라미터를 사용한다.
//
// Metal 변환 시 frag 함수의 albedo/smp 파라미터는
// [[texture(0)]] / [[sampler(0)]] 어노테이션을 붙여 사용해야 하지만,
// Salvation 언어 레벨에서는 타입만 명시하면 codegen이 처리한다.

@backend(metal)
fn main() {
    // salvation이 Metal 보일러플레이트를 자동 생성한다.
}

// ── vertex shader ─────────────────────────────────────────────
// position: 클립 공간 좌표 (float4)
// uv:       텍스처 좌표 0~1 (float2)
@backend(metal) @vertex
fn vert(position: float4, uv: float2) -> float4 {
    return position;
}

// ── fragment shader ───────────────────────────────────────────
// albedo: 텍스처 (texture2d)
// smp:    샘플러  (sampler)
// uv:     텍스처 좌표 (float2)
@backend(metal) @fragment
fn frag(albedo: texture2d, smp: sampler, uv: float2) -> float4 {
    // sample(tex, smp, coord) → Metal의 tex.sample(smp, coord) 로 변환됨.
    return sample(albedo, smp, uv);
}
